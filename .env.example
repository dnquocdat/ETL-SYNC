# ============================================================
# ETL-SYNC Environment Configuration
# Copy this to .env and customize as needed
# ============================================================

# ── MySQL ──────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpwd
MYSQL_DATABASE=etl_db

# ── Kafka ──────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka1:29092,kafka2:29092,kafka3:29092
KAFKA_TOPIC_PATTERN=mysql_server\.etl_db\..*
KAFKA_MAX_OFFSETS_PER_TRIGGER=5000

# ── MongoDB ────────────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017
MONGO_DATABASE=etl_db

# ── Spark ──────────────────────────────────────────────────────
SPARK_LOG_LEVEL=WARN
PROCESSING_TIME=5 seconds
CHECKPOINT_LOCATION=/opt/spark-app/checkpoint

# ── Dead Letter Queue ──────────────────────────────────────────
DLQ_ENABLED=true
DLQ_TOPIC=dlq.etl_sync

# ── Metrics ────────────────────────────────────────────────────
METRICS_ENABLED=true
PUSHGATEWAY_URL=http://pushgateway:9091
METRICS_JOB_NAME=etl_sync_spark

# ── Grafana ────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
